+"""Integration tests for the conformance suite runner."""
+
+import pytest
+from app.conformance.runner import run_conformance_suite
+from app.models.conformance import ConformanceReport
+
+@pytest.mark.asyncio
+async def test_conformance_runner():
+    """Test the conformance runner against an invalid URL to ensure it handles errors properly."""
+    # We test the runner function directly with real httpx request to our FastAPI app
+    # but instead of running a live server we mock the client.
+    # To keep it simple, we just check the report shape using an invalid URL
+    
+    report = await run_conformance_suite("http://localhost:9999", "test-key", include_write_tests=False)
+    
+    assert isinstance(report, ConformanceReport)
+    assert report.base_url == "http://localhost:9999"
+    assert "ERROR" in report.summary
+    assert report.summary["ERROR"] > 0
