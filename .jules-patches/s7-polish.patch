+"""Models for the conformance suite and governance."""
+
+from typing import Optional, List, Any, Dict
+from pydantic import BaseModel
+from datetime import date, datetime
+
+class GovernanceEntry(BaseModel):
+    """A governance entry for an endpoint."""
+    endpoint: str
+    safety_class: str
+    auth_required: bool
+    logging_policy: str
+    readiness_gated: bool
+    approved_by: Optional[str] = None
+    approved_date: Optional[date] = None
+
+class ParityCoverageEntry(BaseModel):
+    """A parity coverage entry for a capability."""
+    capability: str
+    implemented: bool
+    safe_domain_endpoint: Optional[str] = None
+    raw_endpoint: Optional[str] = None
+    constraints: Optional[str] = None
+    known_broker_variance: Optional[str] = None
+    test_coverage: str
+
+class ConformanceResult(BaseModel):
+    """A single conformance test result."""
+    probe: str
+    endpoint: str
+    status: str
+    message: str
+    duration_ms: float
+    details: Optional[Dict[str, Any]] = None
+
+class ConformanceReport(BaseModel):
+    """A full conformance report."""
+    timestamp: datetime
+    base_url: str
+    summary: Dict[str, int]
+    recommendation: str
+    results: List[ConformanceResult]
