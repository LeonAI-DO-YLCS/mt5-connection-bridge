@@ -0,0 +1,64 @@
+"""Runner for the conformance suite."""
+
+import time
+import httpx
+from datetime import datetime, timezone
+from typing import List
+
+from app.models.conformance import ConformanceReport, ConformanceResult
+from app.conformance.probes import (
+    run_connection_probe,
+    run_symbols_probe,
+    run_pricing_probe,
+    run_calculations_probe,
+    run_market_book_probe,
+    run_write_tests_probe
+)
+
+async def run_conformance_suite(base_url: str, api_key: str, include_write_tests: bool = False) -> ConformanceReport:
+    """Run the conformance suite and generate a report."""
+    results: List[ConformanceResult] = []
+    
+    # Configure httpx client
+    headers = {}
+    if api_key:
+        headers["X-API-KEY"] = api_key
+        headers["Authorization"] = f"Bearer {api_key}"
+        
+    async with httpx.AsyncClient(base_url=base_url, headers=headers, timeout=10.0) as client:
+        # Run probes
+        results.extend(await run_connection_probe(client))
+        results.extend(await run_symbols_probe(client))
+        results.extend(await run_pricing_probe(client))
+        results.extend(await run_calculations_probe(client))
+        results.extend(await run_market_book_probe(client))
+        
+        if include_write_tests:
+            results.extend(await run_write_tests_probe(client))
+            
+    # Compute summary
+    summary = {"PASS": 0, "WARN": 0, "FAIL": 0, "ERROR": 0}
+    for result in results:
+        if result.status in summary:
+            summary[result.status] += 1
+        else:
+            summary[result.status] = 1
+            
+    # Recommendation logic (simplified)
+    recommendation = "max_compat"
+    if summary["ERROR"] > 0 or summary["FAIL"] > 0:
+        recommendation = "max_compat (Requires investigation)"
+    elif summary["WARN"] > 0:
+        recommendation = "balanced"
+    else:
+        recommendation = "strict_safe"
+        
+    report = ConformanceReport(
+        timestamp=datetime.now(timezone.utc),
+        base_url=base_url,
+        summary=summary,
+        recommendation=recommendation,
+        results=results
+    )
+    
+    return report
