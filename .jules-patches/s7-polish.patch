+"""Reporter for the conformance suite."""
+
+from pathlib import Path
+from app.models.conformance import ConformanceReport
+
+def generate_json_report(report: ConformanceReport, output_path: str) -> None:
+    """Generate a JSON report."""
+    path = Path(output_path)
+    with path.open("w") as f:
+        # Use model_dump_json for pydantic v2
+        f.write(report.model_dump_json(indent=2))
+
+def generate_markdown_report(report: ConformanceReport, output_path: str) -> None:
+    """Generate a Markdown report."""
+    lines = []
+    lines.append("# Conformance Report")
+    lines.append(f"**Timestamp:** {report.timestamp.isoformat()}")
+    lines.append(f"**Base URL:** {report.base_url}")
+    lines.append(f"**Recommendation:** {report.recommendation}")
+    lines.append("")
+    
+    lines.append("## Summary")
+    for status, count in report.summary.items():
+        lines.append(f"- **{status}:** {count}")
+    lines.append("")
+    
+    lines.append("## Results")
+    lines.append("| Probe | Endpoint | Status | Message | Duration (ms) |")
+    lines.append("|---|---|---|---|---|")
+    for r in report.results:
+        lines.append(f"| {r.probe} | {r.endpoint} | {r.status} | {r.message} | {r.duration_ms:.2f} |")
+        
+    path = Path(output_path)
+    with path.open("w") as f:
+        f.write("\n".join(lines))
