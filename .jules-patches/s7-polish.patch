+"""Calculations probe for the conformance suite."""
+
+import time
+import httpx
+from typing import List
+from app.models.conformance import ConformanceResult
+
+async def run_calculations_probe(client: httpx.AsyncClient) -> List[ConformanceResult]:
+    """Test calculation endpoints."""
+    results: List[ConformanceResult] = []
+    
+    endpoints = [
+        {"path": "/margin-check", "params": {"symbol": "EURUSD", "action": 0, "volume": 0.1, "price": 1.1000}},
+        {"path": "/profit-calc", "params": {"symbol": "EURUSD", "action": 0, "volume": 0.1, "price_open": 1.1000, "price_close": 1.1050}},
+        {"path": "/mt5/raw/margin-check", "params": {"symbol": "EURUSD", "action": 0, "volume": 0.1, "price": 1.1000}},
+        {"path": "/mt5/raw/profit-calc", "params": {"symbol": "EURUSD", "action": 0, "volume": 0.1, "price_open": 1.1000, "price_close": 1.1050}}
+    ]
+
+    for endpoint in endpoints:
+        start_time = time.time()
+        try:
+            response = await client.get(endpoint["path"], params=endpoint["params"])
+            duration = (time.time() - start_time) * 1000
+            
+            # Since these might fail due to EURUSD not existing or no connection,
+            # we consider 200, 404 or 422 a PASS for conformance (endpoint exists and handles input)
+            status = "PASS" if response.status_code in (200, 404, 422) else "FAIL"
+            message = f"HTTP {response.status_code}"
+            
+            results.append(ConformanceResult(
+                probe="calculations",
+                endpoint=endpoint["path"],
+                status=status,
+                message=message,
+                duration_ms=duration
+            ))
+        except Exception as e:
+            results.append(ConformanceResult(
+                probe="calculations",
+                endpoint=endpoint["path"],
+                status="ERROR",
+                message=str(e),
+                duration_ms=(time.time() - start_time) * 1000
+            ))
+        
+    return results
