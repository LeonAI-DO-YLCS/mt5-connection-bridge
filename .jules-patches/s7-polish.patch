+"""Conformance suite CLI entry point."""
+
+import argparse
+import asyncio
+from app.conformance.runner import run_conformance_suite
+from app.conformance.reporter import generate_json_report, generate_markdown_report
+
+async def main() -> None:
+    """Run the conformance suite and output the reports."""
+    parser = argparse.ArgumentParser(description="Run MT5 Bridge conformance suite.")
+    parser.add_argument("--base-url", required=True, help="Base URL of the bridge (e.g. http://localhost:8001)")
+    parser.add_argument("--api-key", required=True, help="API key to use for authentication")
+    parser.add_argument("--include-write-tests", action="store_true", help="Include write tests (creates and cancels test orders)")
+    parser.add_argument("--output-json", type=str, help="Output JSON report to this path")
+    parser.add_argument("--output-md", type=str, help="Output Markdown report to this path")
+    
+    args = parser.parse_args()
+    
+    report = await run_conformance_suite(
+        base_url=args.base_url,
+        api_key=args.api_key,
+        include_write_tests=args.include_write_tests
+    )
+    
+    print(f"Conformance run completed. {report.summary.get('PASS', 0)} pass, {report.summary.get('WARN', 0)} warn, {report.summary.get('FAIL', 0)} fail, {report.summary.get('ERROR', 0)} error.")
+    print(f"Recommendation: {report.recommendation}")
+    
+    if args.output_json:
+        generate_json_report(report, args.output_json)
+        print(f"JSON report written to {args.output_json}")
+        
+    if args.output_md:
+        generate_markdown_report(report, args.output_md)
+        print(f"Markdown report written to {args.output_md}")
+        
+    if not args.output_json and not args.output_md:
+        print(report.model_dump_json(indent=2))
+
+if __name__ == "__main__":
+    asyncio.run(main())
