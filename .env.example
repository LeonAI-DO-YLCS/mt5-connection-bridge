# MT5 Bridge Configuration
# Copy this file to .env and fill in your values

# === Bridge Server ===
MT5_BRIDGE_PORT=8001
MT5_BRIDGE_API_KEY=change-me-to-a-secure-random-string

# === MetaTrader 5 Credentials ===
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=Deriv-Demo

# === MT5 Terminal Path (optional, auto-detected if not set) ===
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# === Logging ===
LOG_LEVEL=INFO
LAUNCHER_PREFER_WINDOWS=true
LAUNCHER_AUTO_SETUP_WINDOWS_VENV=true
# TUI mode: auto | true | false
LAUNCHER_TUI_MODE=auto
# TUI refresh cadence (seconds)
LAUNCHER_TUI_REFRESH_SECONDS=1
# Endpoint probe cadence for TUI status (seconds)
LAUNCHER_TUI_PROBE_SECONDS=5
# Keep runtime request/access logs persisted (always on)
LAUNCHER_UVICORN_ACCESS_LOG=true

# === Optional Windows Python override for WSL wrapper ===
# Recommended: Python 3.10-3.12 for best MetaTrader5 wheel compatibility
# MT5_WINDOWS_PYTHON=C:\Users\<you>\AppData\Local\Programs\Python\Python312\python.exe

# === Dashboard / Safety Policy ===
EXECUTION_ENABLED=false
RUNTIME_STATE_PATH=logs/bridge/runtime_state.json
METRICS_RETENTION_DAYS=90
MULTI_TRADE_OVERLOAD_QUEUE_THRESHOLD=100
MAX_PRE_DISPATCH_SLIPPAGE_PCT=1.0
MAX_POST_FILL_SLIPPAGE_PCT=1.0
