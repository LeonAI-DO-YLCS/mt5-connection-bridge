# MT5 Bridge Configuration
# Copy this file to .env and fill in your values

# === Bridge Server ===
MT5_BRIDGE_PORT=8001
MT5_BRIDGE_API_KEY=change-me-to-a-secure-random-string

# === MetaTrader 5 Credentials ===
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=Deriv-Demo

# === MT5 Terminal Path (optional, auto-detected if not set) ===
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# === Logging ===
LOG_LEVEL=INFO

# === Dashboard / Safety Policy ===
EXECUTION_ENABLED=false
RUNTIME_STATE_PATH=logs/runtime_state.json
METRICS_RETENTION_DAYS=90
MULTI_TRADE_OVERLOAD_QUEUE_THRESHOLD=100
MAX_PRE_DISPATCH_SLIPPAGE_PCT=1.0
MAX_POST_FILL_SLIPPAGE_PCT=1.0
